<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Shared test support library: opt out of xUnit runner injection -->
    <IsTestProject>false</IsTestProject>
    <UseXUnit>false</UseXUnit>
  </PropertyGroup>

  <ItemGroup>
    <!-- TUnit core + assertions for abstract test suite base classes -->
    <PackageReference Include="TUnit.Core" Version="0.*" />
    <PackageReference Include="TUnit.Assertions" Version="0.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Kista\Kista.csproj" />
    <ProjectReference Include="..\Kista.MultiTenant.Testing\Kista.MultiTenant.Testing.csproj" />
    <ProjectReference Include="..\Kista.Testing.Utils\Kista.Testing.Utils.csproj" />
  </ItemGroup>

</Project>

